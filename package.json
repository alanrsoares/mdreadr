{
  "name": "mdreadr",
  "version": "0.1.0",
  "module": "src/bun/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "hmr": "vite",
    "start": "vite build && GDK_BACKEND=x11 WEBKIT_DISABLE_DMABUF_RENDERER=1 electrobun dev",
    "dev": "vite build && GDK_BACKEND=x11 WEBKIT_DISABLE_DMABUF_RENDERER=1 electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "build": "bun run theme:build && vite build && electrobun build --env=stable",
    "icons:build": "bun run scripts/build-icons.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "tersify": "onrails-codemod-neverthrow . --tersify",
    "tersify:dry": "onrails-codemod-neverthrow . --tersify --dry",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "astryx": "node node_modules/@astryxdesign/cli/bin/astryx.mjs",
    "theme:build": "npm run astryx -- theme build src/webview/app/theme/mdreadrTheme.ts --out src/webview/app/theme/mdreadr.css",
    "check": "biome ci --error-on-warnings . && bun run typecheck && bun test"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.5",
    "@astryxdesign/theme-neutral": "^0.1.5",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/eden": "^1.4.9",
    "@heroicons/react": "^2.2.0",
    "@onrails/maybe": "^0.2.3",
    "@onrails/pattern": "^0.3.2",
    "@onrails/result": "^0.4.0",
    "@styled-cva/react": "^0.7.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.18",
    "electrobun": "^1.18.1",
    "elysia": "^1.4.29",
    "katex": "^0.17.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.3.2",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.5",
    "@biomejs/biome": "^2.5.3",
    "@onrails/codemod": "^0.2.4",
    "@resvg/resvg-js": "^2.6.2",
    "@styled-cva/biome-plugin": "^0.1.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
